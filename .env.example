# Frontend variables. These are bundled into the GitHub Pages build.
# The Supabase anon/publishable key is public by design; never put service-role secrets here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_GITHUB_REPOSITORY_NAME=world-cup-predictor-2026

# Server-side GitHub Actions fixture sync only. Do not expose these in frontend code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-private-service-role-key
FOOTBALL_API_KEY=your-api-sports-football-key
FOOTBALL_API_HOST=https://v3.football.api-sports.io
FIXTURE_PROVIDER=api-football
