# Frontend variables.
# These are bundled into the GitHub Pages build.
# Supabase anon/publishable key is public by design.
# Never put service-role secrets in frontend variables.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_GITHUB_REPOSITORY_NAME=world-cup-predictor-2026

# Fixture source used by the app/scripts.
# ESPN is the primary no-key public scoreboard feed.
FIXTURE_PROVIDER=espn

# GitHub Actions secrets only.
# Do NOT put real values here.
# Add these in GitHub:
# Repo > Settings > Secrets and variables > Actions > New repository secret
#
# Required secret names:
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
#
# SUPABASE_SERVICE_ROLE_KEY must never be exposed in frontend code.